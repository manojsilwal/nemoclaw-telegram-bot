{
  "gateway": {
    "mode": "local",
    "port": 8080,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["https://nemoclaw-telegram-bot.onrender.com"]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/workspace",
      "model": {
        "primary": "google/gemini-2.5-pro"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },
  "browser": {
    "enabled": false
  },
  "tools": {
    "web": {
      "search": {
        "provider": "firecrawl"
      }
    }
  },
  "plugins": {
    "entries": {
      "firecrawl": {
        "enabled": true,
        "config": {
          "webFetch": {
            "apiKey": "${FIRECRAWL_API_KEY}"
          },
          "webSearch": {
            "apiKey": "${FIRECRAWL_API_KEY}"
          }
        }
      }
    }
  }
}
