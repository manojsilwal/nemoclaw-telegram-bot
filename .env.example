# Copy to .env for local docker compose experiments, or set in Render Dashboard.
# See: https://docs.openclaw.ai/gateway/configuration
#
# OPENCLAW_GATEWAY_TOKEN: generate a new secret (do not reuse committed examples):
#   openssl rand -hex 32

OPENCLAW_GATEWAY_TOKEN=

# Google Gemini (Google AI Studio / API key). Also accepted: GOOGLE_API_KEY
# Many setups keep only GOOGLE_API_KEY in ~/.zshrc; scripts/gcp-deploy-from-local.sh
# copies it into both GEMINI_API_KEY and GOOGLE_API_KEY in the VM .env.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Telegram Bot API token from @BotFather (OpenClaw uses long-polling by default).
TELEGRAM_BOT_TOKEN=

# Paperclip (running on the same VM at localhost:3100)
# Company ID: DreamRise  |  CEO Agent: "DreamRise Chief" (name from company config)
# Leave PAPERCLIP_API_KEY blank if running in local/trusted mode (default for local dev)
# On GCP via docker-compose, PAPERCLIP_URL uses the internal service name
PAPERCLIP_URL=http://paperclip:3100
PAPERCLIP_COMPANY_ID=DreamRise
PAPERCLIP_CEO_AGENT_ID=DreamRise Chief
PAPERCLIP_API_KEY=
BETTER_AUTH_SECRET=

# Oracle MCP — use a gitignored file (see .env.oracle.example):
#   cp .env.oracle.example .env.oracle.local
#   # edit .env.oracle.local with USER/PASS@host:1521/service
#   source scripts/load-oracle-env.sh && cursor .
